{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "@voice-notes/shared": [
        "packages/shared/src/index.ts"
      ],
      "@voice-notes/shared/*": [
        "packages/shared/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "storybook-static"
  ]
}
