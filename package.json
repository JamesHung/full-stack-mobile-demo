{
  "name": "voice-notes-summary",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "lint": "tsc --noEmit -p tsconfig.base.json",
    "test": "vitest run",
    "build": "corepack pnpm --filter @voice-notes/shared build",
    "storybook:build": "storybook build -c .storybook -o storybook-static",
    "chromatic": "corepack pnpm storybook:build && chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --storybook-build-dir=storybook-static"
  },
  "devDependencies": {
    "@voice-notes/smoke-kit": "workspace:*",
    "@storybook/react": "^8.6.11",
    "@storybook/react-webpack5": "^8.6.11",
    "@storybook/test": "8.6.18",
    "babel-loader": "^9.2.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "chromatic": "^11.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
